# Grafana Cloud (for OpenTelemetry export via Alloy)
GRAFANA_OTLP_USERNAME=your-grafana-instance-id
GRAFANA_OTLP_API_KEY=your-grafana-cloud-api-key

# API service
PORT=3001
APP_SERVICE_URL=localhost:50051

# Frontend (local dev only)
VITE_API_URL=http://localhost:3001

# Application service
GRPC_PORT=50051
OPENAI_API_KEY=your-openai-api-key-here

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=todos
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
